# Copie este arquivo para .env.local e preencha os valores do seu projeto.
# .env.local é ignorado pelo Git — nunca commite valores reais.

# Supabase (client-side; nomes usados por lib/supabase/client.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only; M1-F S4-A2B — Route Handlers de convites).
# NUNCA prefixar com NEXT_PUBLIC_, NUNCA importar de código client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Origem confiável usada para validar Origin e construir o link de convite
# (M1-F S4-A2B). Server-only — nunca derivada de Host/Origin recebido na
# requisição. URL absoluta http/https, sem credenciais, sem path/query.
# Local: http://127.0.0.1:3000
APP_URL=

# M1-D — estágios remotos do pipeline.
# Permanece false por padrão; ligue somente após a validação do módulo.
# Override via localStorage ('autocrm_ff_remote_stages') funciona SOMENTE em
# development; produção ignora totalmente o override e usa apenas esta variável.
NEXT_PUBLIC_FF_REMOTE_STAGES=false

# M1-E — leads remotos.
# Permanece false por padrão; ligue somente após a validação do módulo.
# Override via localStorage ('autocrm_ff_remote_leads') funciona SOMENTE em
# development; produção ignora totalmente o override e usa apenas esta variável.
NEXT_PUBLIC_FF_REMOTE_LEADS=false
